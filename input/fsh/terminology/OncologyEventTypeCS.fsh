CodeSystem: OncologyEventTypeCS
Id: oncology-event-type-cs
Title: "Oncology Event Type Codesystem"
Description: "Oncology event type codes with English and Russian translations"

* insert OriginalCodeSystemDraft(oncology-event-type-cs)

* #cancr0006.00001 "Harakatsiz"
  * ^designation[0].language = #ru
  * ^designation[=].value = "Нет сведений"
  * ^designation[+].language = #en
  * ^designation[=].value = "Inactive"

* #cancr0006.00002 "Qaytarilish"
  * ^designation[0].language = #ru
  * ^designation[=].value = "Рецидив"
  * ^designation[+].language = #en
  * ^designation[=].value = "Relapse"

