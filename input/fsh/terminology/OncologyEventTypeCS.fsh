  * ^designation[0].language = #ru
  * ^designation[=].value = "Отдаленные метастазы"
  * ^designation[+].language = #en
  * ^designation[=].value = "Distant metastases"

* #cancr0006.00005 "Biokimyoviy relaps"
  * ^designation[0].language = #ru
  * ^designation[=].value = "Биохимический рецидив"
  * ^designation[+].language = #en
  * ^designation[=].value = "Biochemical relapse"

* #cancr0006.00006 "Jarayonning rivojlanishi"
  * ^designation[0].language = #ru
  * ^designation[=].value = "Прогрессирование процесса"
  * ^designation[+].language = #en
  * ^designation[=].value = "Progression of the process"

* #cancr0006.00007 "Mahalliy rivojlangan jarayon"
  * ^designation[0].language = #ru
  * ^designation[=].value = "Местнораспространенный процесс"
  * ^designation[+].language = #en
  * ^designation[=].value = "Locally advanced process"

* #cancr0006.00008 "Transformatsiya"
  * ^designation[0].language = #ru
  * ^designation[=].value = "Трансформация"
  * ^designation[+].language = #en
  * ^designation[=].value = "Transformation"