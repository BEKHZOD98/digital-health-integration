  * ^designation[=].value = "SMARCB1 (SWI/SNF Related, Matrix Associated, Actin Dependent Regulator Of Chromatin, Subfamily B, Member 1) Protein involved in chromatin remodeling"

* #cancr0004.00179 "SMARCE1 (SWI/SNF bilan bog'liq, matritsa bilan bog'liq, xromatinning aktinga bog'liq regulyatori, E subfamily, a'zo 1) Xromatinni qayta qurishda ishtirok etadigan oqsil."
  * ^designation[0].language = #ru
  * ^designation[=].value = "SMARCE1 (SWI/SNF Related, Matrix Associated, Actin Dependent Regulator Of Chromatin, Subfamily E, Member 1) Белок, участвующий в ремоделировании хроматина."
  * ^designation[+].language = #en
  * ^designation[=].value = "SMARCE1 (SWI/SNF Related, Matrix Associated, Actin Dependent Regulator Of Chromatin, Subfamily E, Member 1) Protein involved in chromatin remodeling."

* #cancr0004.00180 "SOS1 (SOS Ras/Rac Guanin Nukleotid almashinuvi omili 1) Ras faollashuvida ishtirok etadigan oqsil. Mutatsiyalar Noonan sindromi bilan bog'liq."
  * ^designation[0].language = #ru
  * ^designation[=].value = "SOS1 (SOS Ras/Rac Guanine Nucleotide Exchange Factor 1) Белок, участвующий в активации Ras. Мутации связаны с синдромом Нунан."
  * ^designation[+].language = #en
  * ^designation[=].value = "SOS1 (SOS Ras/Rac Guanine Nucleotide Exchange Factor 1) A protein involved in Ras activation. Mutations are associated with Noonan syndrome."

* #cancr0004.00181 "SOS2 (SOS Ras/Rac guanin nukleotid almashinuvi omili 2) Ras faollashuvida ishtirok etgan oqsil"
  * ^designation[0].language = #ru
  * ^designation[=].value = "SOS2 (SOS Ras/Rac Guanine Nucleotide Exchange Factor 2) Белок, участвующий в активации Ras"
  * ^designation[+].language = #en
  * ^designation[=].value = "SOS2 (SOS Ras/Rac Guanine Nucleotide Exchange Factor 2) A protein involved in Ras activation"

* #cancr0004.00182 "SPINK1 (Serine Peptidase Inhibitor Kazal Type 1) Serin proteazalarini inhibe qiluvchi oqsil."
  * ^designation[0].language = #ru
  * ^designation[=].value = "SPINK1 (Serine Peptidase Inhibitor Kazal Type 1) Белок, ингибирующий сериновые протеазы."
  * ^designation[+].language = #en
  * ^designation[=].value = "SPINK1 (Serine Peptidase Inhibitor Kazal Type 1) A protein that inhibits serine proteases."

* #cancr0004.00183 "SPRED1 (Sprouty Related EVH1 Domain Containing 1) Ras/MAPK signalizatsiya yo'lini inhibe qiluvchi oqsil. Mutatsiyalar Legus sindromi bilan bog'liq."
  * ^designation[0].language = #ru
  * ^designation[=].value = "SPRED1 (Sprouty Related EVH1 Domain Containing 1) Белок, ингибирующий сигнальные пути Ras/MAPK. Мутации связаны с синдромом Легуса."
  * ^designation[+].language = #en
  * ^designation[=].value = "SPRED1 (Sprouty Related EVH1 Domain Containing 1) A protein that inhibits Ras/MAPK signaling pathways. Mutations are associated with Legus syndrome."

* #cancr0004.00184 "SRGAP1 (SLIT-ROBO Rho GTPase faollashtiruvchi oqsil 1) Aktin sitoskeletini va hujayra migratsiyasini tartibga solishda ishtirok etadigan oqsil."
  * ^designation[0].language = #ru
  * ^designation[=].value = "SRGAP1 (SLIT-ROBO Rho GTPase Activating Protein 1) Белок, участвующий в регуляции актинового цитоскелета и клеточной миграции."
  * ^designation[+].language = #en
  * ^designation[=].value = "SRGAP1 (SLIT-ROBO Rho GTPase Activating Protein 1) A protein involved in the regulation of the actin cytoskeleton and cell migration."

* #cancr0004.00185 "SRP72 (Signal Recognition Particle 72) Ribosoma biogenezi va translyatsiyasida ishtirok etadigan oqsil. Mutatsiyalar aplastik anemiya bilan bog'liq bo'lishi mumkin."
  * ^designation[0].language = #ru
  * ^designation[=].value = "SRP72 (Signal Recognition Particle 72) Белок, участвующий в биогенезе рибосом и трансляции. Мутации могут быть связаны с апластической анемией."
  * ^designation[+].language = #en
  * ^designation[=].value = "SRP72 (Signal Recognition Particle 72) A protein involved in ribosome biogenesis and translation. Mutations may be associated with aplastic anemia."

* #cancr0004.00186 "STAT3 (Signal Transducer and activator Of Transkripsiya 3) Hujayra o'sishi va omon qolishini tartibga solishda ishtirok etadigan transkripsiya omili. Mutatsiyalar giper IgE sindromi (Job sindromi) va turli xil saraton turlari bilan bog'liq."
  * ^designation[0].language = #ru
  * ^designation[=].value = "STAT3 (Signal Transducer And Activator Of Transcription 3)Транскрипционный фактор, участвующий в регуляции клеточного роста и выживания. Мутации связаны с гипер IgE синдромом (синдром Джоба) и различными видами рака."
  * ^designation[+].language = #en
  * ^designation[=].value = "STAT3 (Signal Transducer And Activator Of Transcription 3) A transcription factor involved in the regulation of cell growth and survival. Mutations are associated with hyper IgE syndrome (Job's syndrome) and various cancers."

* #cancr0004.00187 "STK11 (Serin/Treonin Kinaz 11) Uyali metabolizm va o'sishda rol o'ynaydigan kinaz. Mutatsiyalar Peutz-Jegers sindromini keltirib chiqaradi va turli xil saraton kasalliklari xavfini oshiradi."
  * ^designation[0].language = #ru
  * ^designation[=].value = "STK11 (Serine/Threonine Kinase 11) Киназа, играющая роль в клеточном метаболизме и росте. Мутации вызывают синдром Пейтца-Егерса и связаны с повышенным риском различных видов рака."
  * ^designation[+].language = #en
  * ^designation[=].value = "STK11 (Serine/Threonine Kinase 11) A kinase that plays a role in cellular metabolism and growth. Mutations cause Peutz-Jeghers syndrome and are associated with an increased risk of various cancers."

* #cancr0004.00188 "SUFU (eritilgan gomologni bostiruvchi) Kirpi signalizatsiya yo'lini inhibe qiluvchi oqsil. Mutatsiyalar medulloblastomalar va boshqa o'smalar bilan bog'liq."
  * ^designation[0].language = #ru
  * ^designation[=].value = "SUFU (Suppressor Of Fused Homolog) Белок, ингибирующий сигнальный путь Hedgehog. Мутации связаны с медуллобластомами и другими опухолями."
  * ^designation[+].language = #en
  * ^designation[=].value = "SUFU (Suppressor Of Fused Homolog) A protein that inhibits the Hedgehog signaling pathway. Mutations are associated with medulloblastomas and other tumors."

* #cancr0004.00189 "TERC telomeraza RNK komponenti) telomera uzunligini saqlashda rol o'ynaydigan telomeraza komponenti. Mutatsiyalar diskeroz konjenit va boshqa telomeropatiyalar bilan bog'liq bo'lishi mumkin."
  * ^designation[0].language = #ru
  * ^designation[=].value = "TERC Telomerase RNA Component) Компонент теломеразы, играющий роль в поддержании длины теломер. Мутации могут быть связаны с дискерозисом конгенита и другими теломеропатиями."
  * ^designation[+].language = #en
  * ^designation[=].value = "TERC Telomerase RNA Component) A component of telomerase that plays a role in maintaining telomere length. Mutations may be associated with dyskerosis congenita and other telomeropathies."

* #cancr0004.00190 "TERT (telomeraza teskari transkriptaza) telomerazaning katalitik sub birligi. Mutatsiyalar saratonning turli shakllari va telomerlarning qisqarishi bilan bog'liq kasalliklar bilan bog'liq."
  * ^designation[0].language = #ru
  * ^designation[=].value = "TERT (Telomerase Reverse Transcriptase) Каталитическая субъединица теломеразы. Мутации связаны с различными формами рака и заболеваниями, связанными с укорочением теломер."
  * ^designation[+].language = #en
  * ^designation[=].value = "TERT (Telomerase Reverse Transcriptase) The catalytic subunit of telomerase. Mutations are associated with various forms of cancer and diseases associated with telomere shortening."

* #cancr0004.00191 "TINF2 (TERF1-O'zaro ta'sir qiluvchi yadro omili 2) Telomer tuzilishini saqlashda ishtirok etadigan oqsil. Mutatsiyalar diskerozli konjenit va boshqa telomeropatiyalarga olib kelishi mumkin."
  * ^designation[0].language = #ru
  * ^designation[=].value = "TINF2 (TERF1-Interacting Nuclear Factor 2) Белок, участвующий в поддержании структуры теломер. Мутации могут вызывать дискерозис конгенита и другие теломеропатии."
  * ^designation[+].language = #en
  * ^designation[=].value = "TINF2 (TERF1-Interacting Nuclear Factor 2) A protein involved in maintaining telomere structure. Mutations can cause dyskerosis congenita and other telomeropathies."

* #cancr0004.00192 "TJP2 (Tight Junction Protein 2) Qattiq hujayralararo birikmalar hosil bo'lishida ishtirok etadigan oqsil. Mutatsiyalar progressiv oilaviy kolestaz bilan bog'liq."
  * ^designation[0].language = #ru
  * ^designation[=].value = "TJP2 (Tight Junction Protein 2) Белок, участвующий в формировании плотных межклеточных контактов. Мутации связаны с прогрессирующей семейной холестазой."
  * ^designation[+].language = #en
  * ^designation[=].value = "TJP2 (Tight Junction Protein 2) A protein involved in the formation of tight intercellular junctions. Mutations are associated with progressive familial cholestasis."

* #cancr0004.00193 "TMEM127 (Transmembran oqsili 127) Hujayra o'sishini tartibga solishda rol o'ynaydigan oqsil. Mutatsiyalar feokromotsitomalar va paragangliomalar bilan bog'liq."
  * ^designation[0].language = #ru
  * ^designation[=].value = "TMEM127 (Transmembrane Protein 127) Белок, играющий роль в регуляции клеточного роста. Мутации связаны с феохромоцитомами и параганглиомами."
  * ^designation[+].language = #en
  * ^designation[=].value = "TMEM127 (Transmembrane Protein 127) A protein that plays a role in the regulation of cell growth. Mutations are associated with pheochromocytomas and paragangliomas."

* #cancr0004.00194 "TP53 (Tumor Protein p53) O'smani bostirish, hujayra siklini tartibga solish va apoptozda asosiy rol o'ynaydigan transkripsiya omili. Mutatsiyalar saratonning ko'plab shakllari bilan bog'liq."
  * ^designation[0].language = #ru
  * ^designation[=].value = "TP53 (Tumor Protein p53) Транскрипционный фактор, играющий ключевую роль в супрессии опухолей, регуляции клеточного цикла и апоптозе. Мутации связаны с многочисленными формами рака."
  * ^designation[+].language = #en
  * ^designation[=].value = "TP53 (Tumor Protein p53) A transcription factor that plays a key role in tumor suppression, cell cycle regulation, and apoptosis. Mutations are associated with numerous forms of cancer."

* #cancr0004.00195 "TSC1 (tuberoz skleroz 1) Hujayra o'sishi va bo'linishini tartibga solishda ishtirok etadigan oqsil. Mutatsiyalar turli organlarda yaxshi xulqli o'smalar bilan ajralib turadigan tuberous sklerozni keltirib chiqaradi."
  * ^designation[0].language = #ru
  * ^designation[=].value = "TSC1 (Tuberous Sclerosis 1) Белок, участвующий в регуляции клеточного роста и деления. Мутации вызывают туберозный склероз, характеризующийся доброкачественными опухолями в различных органах."
  * ^designation[+].language = #en
  * ^designation[=].value = "TSC1 (Tuberous Sclerosis 1) A protein involved in the regulation of cell growth and division. Mutations cause tuberous sclerosis, characterized by benign tumors in various organs."

* #cancr0004.00196 "TSC2 (Tuberous sklerosis 2) mTOR signalizatsiya yo'lini inhibe qilish uchun TSC1 bilan o'zaro ta'sir qiluvchi oqsil. Mutatsiyalar ham tuberous sklerozga olib keladi."
  * ^designation[0].language = #ru
  * ^designation[=].value = "TSC2 (Tuberous Sclerosis 2) Белок, взаимодействующий с TSC1 для ингибирования mTOR сигнального пути. Мутации также вызывают туберозный склероз."
  * ^designation[+].language = #en
  * ^designation[=].value = "TSC2 (Tuberous Sclerosis 2) A protein that interacts with TSC1 to inhibit the mTOR signaling pathway. Mutations also cause tuberous sclerosis."

* #cancr0004.00197 "UBE2T (Ubiquitin Conjugating Enzyme E2 T) Ubiquitinatsiya jarayonida ishtirok etadigan, oqsil parchalanishi va hujayra jarayonlarini tartibga solish uchun muhim bo'lgan oqsil. Mutatsiyalar Fankoni anemiya sindromi bilan bog'liq."
  * ^designation[0].language = #ru
  * ^designation[=].value = "UBE2T (Ubiquitin Conjugating Enzyme E2 T) Белок, участвующий в процессе убиквитинирования, важном для деградации белков и регуляции клеточных процессов. Мутации связаны с синдромом Fanconi anemia."
  * ^designation[+].language = #en
  * ^designation[=].value = "UBE2T (Ubiquitin Conjugating Enzyme E2 T) A protein involved in the ubiquitination process, important for protein degradation and regulation of cellular processes. Mutations are associated with Fanconi anemia syndrome."

* #cancr0004.00198 "UROD (uroporfirinogen dekarboksilaza) Gem biosintezida ishtirok etadigan ferment. Mutatsiyalar porfiriya kutana tardega olib keladi."
  * ^designation[0].language = #ru
  * ^designation[=].value = "UROD (Uroporphyrinogen Decarboxylase) Фермент, участвующий в биосинтезе гема. Мутации вызывают порфирию кутану тарду."
  * ^designation[+].language = #en
  * ^designation[=].value = "UROD (Uroporphyrinogen Decarboxylase) An enzyme involved in heme biosynthesis. Mutations cause porphyria cutanea tardu."

* #cancr0004.00199 "VHL (Von Hippel-Lindau o'simtalarini bostiruvchi) gipoksiyani tartibga solishda ishtirok etadigan o'simta bostiruvchi oqsil. Mutatsiyalar fon Hippel-Lindau kasalligini keltirib chiqaradi, bu ko'plab o'smalar bilan tavsiflanadi."
  * ^designation[0].language = #ru
  * ^designation[=].value = "VHL (Von Hippel-Lindau Tumor Suppressor) Белок-супрессор опухолей, участвующий в регуляции гипоксии. Мутации вызывают болезнь фон Гиппеля-Линдау, характеризующуюся множественными опухолями."
  * ^designation[+].language = #en
  * ^designation[=].value = "VHL (Von Hippel-Lindau Tumor Suppressor) A tumor suppressor protein involved in the regulation of hypoxia. Mutations cause von Hippel-Lindau disease, characterized by multiple tumors."

* #cancr0004.00200 "WAS (Wiskott-Aldrich sindromi) - aktin sitoskeletini tartibga solishda ishtirok etadigan oqsil. Mutatsiyalar immunitet tanqisligi va trombotsitopeniya bilan tavsiflangan Wiskott-Aldrich sindromini keltirib chiqaradi."
  * ^designation[0].language = #ru
  * ^designation[=].value = "WAS (Wiskott-Aldrich Syndrome)Белок, участвующий в регуляции актинового цитоскелета. Мутации вызывают синдром Вискотта-Олдрича, характеризующийся иммунодефицитом и тромбоцитопенией."
  * ^designation[+].language = #en
  * ^designation[=].value = "WAS (Wiskott-Aldrich Syndrome) A protein involved in the regulation of the actin cytoskeleton. Mutations cause Wiskott-Aldrich syndrome, characterized by immunodeficiency and thrombocytopenia."

* #cancr0004.00201 "WNT10A (Wnt Oila a'zosi 10A) embrion rivojlanishi va hujayra proliferatsiyasi uchun muhim bo'lgan Wnt signalizatsiya yo'lida ishtirok etadigan oqsil. Mutatsiyalar turli xil rivojlanish anomaliyalari bilan bog'liq bo'lishi mumkin."
  * ^designation[0].language = #ru
  * ^designation[=].value = "WNT10A (Wnt Family Member 10A)Белок, участвующий в сигнальном пути Wnt, важном для эмбрионального развития и клеточной пролиферации. Мутации могут быть связаны с различными аномалиями развития."
  * ^designation[+].language = #en
  * ^designation[=].value = "WNT10A (Wnt Family Member 10A)A protein involved in the Wnt signaling pathway, which is important for embryonic development and cell proliferation. Mutations can be associated with various developmental abnormalities."

* #cancr0004.00202 "WRAP53 (TP53ga WD Repeat Containing Antisense to TP53) Telomeraza stabilizatsiyasi va lokalizatsiyasini tartibga soluvchi, shuningdek, DNKni tiklash jarayonida rol o'ynaydigan oqsil. Mutatsiyalar turli kasalliklar, jumladan, diskeroz konjenit bilan bog'liq."
  * ^designation[0].language = #ru
  * ^designation[=].value = "WRAP53 (WD Repeat Containing Antisense to TP53)Белок, регулирующий стабилизацию и локализацию теломеразы, а также играющий роль в процессе репарации ДНК. Мутации связаны с различными заболеваниями, включая дискерозис конгенита."
  * ^designation[+].language = #en
  * ^designation[=].value = "WRAP53 (WD Repeat Containing Antisense to TP53)A protein that regulates telomerase stabilization and localization, and also plays a role in DNA repair. Mutations are associated with various diseases, including dyskerosis congenita."

* #cancr0004.00203 "WRN Verner sindromi RecQ Helicase kabi) Helikaz genomik barqarorlikni saqlashda ishtirok etadi. Mutatsiyalar Verner sindromini keltirib chiqaradi, bu erta qarish va saraton xavfining oshishi bilan tavsiflanadi."
  * ^designation[0].language = #ru
  * ^designation[=].value = "WRN Werner Syndrome RecQ Like Helicase) Геликаза, участвующая в поддержании геномной стабильности. Мутации вызывают синдром Вернера, характеризующийся преждевременным старением и повышенным риском рака."
  * ^designation[+].language = #en
  * ^designation[=].value = "WRN Werner Syndrome RecQ Like Helicase) A helicase involved in maintaining genomic stability. Mutations cause Werner syndrome, characterized by premature aging and an increased risk of cancer."

* #cancr0004.00204 "WT1 (Wilms Tumor 1) Buyrak va jinsiy bez rivojlanishida rol o'ynaydigan transkripsiya omili. Mutatsiyalar Wilms shishi va boshqa sindromlar bilan bog'liq."
  * ^designation[0].language = #ru
  * ^designation[=].value = "WT1 (Wilms Tumor 1)Транскрипционный фактор, играющий роль в развитии почек и гонад. Мутации связаны с опухолью Вильмса и другими синдромами."
  * ^designation[+].language = #en
  * ^designation[=].value = "WT1 (Wilms Tumor 1)A transcription factor that plays a role in the development of the kidneys and gonads. Mutations are associated with Wilms tumor and other syndromes."

* #cancr0004.00205 "XPA (Xeroderma Pigmentosum, Komplementatsiya guruhi A) ultrabinafsha nurlanish natijasida kelib chiqqan DNK shikastlanishini tiklashda ishtirok etadigan oqsil. Mutatsiyalar ultrabinafsha nurlanishiga yuqori sezuvchanlik va teri saratoni xavfi bilan tavsiflangan kseroderma pigmentozini keltirib chiqaradi."
  * ^designation[0].language = #ru
  * ^designation[=].value = "XPA (Xeroderma Pigmentosum, Complementation Group A) Белок, участвующий в репарации повреждений ДНК, вызванных ультрафиолетовым излучением. Мутации вызывают ксеродерму пигментозу, характеризующуюся повышенной чувствительностью к ультрафиолету и риском рака кожи."
  * ^designation[+].language = #en
  * ^designation[=].value = "XPA (Xeroderma Pigmentosum, Complementation Group A) A protein involved in the repair of DNA damage caused by ultraviolet radiation. Mutations cause xeroderma pigmentosis, characterized by increased sensitivity to ultraviolet radiation and the risk of skin cancer."

* #cancr0004.00206 "XPC (Xeroderma Pigmentosum, Komplementatsiya guruhi C) DNKning nukleotidlar eksizyonini tiklash jarayonida ishtirok etadigan oqsil. Mutatsiyalar kseroderma pigmentozini ham keltirib chiqaradi."
  * ^designation[0].language = #ru
  * ^designation[=].value = "XPC (Xeroderma Pigmentosum, Complementation Group C) Белок, участвующий в процессе нуклеотидной эксцизионной репарации ДНК. Мутации также вызывают ксеродерму пигментозу."
  * ^designation[+].language = #en
  * ^designation[=].value = "XPC (Xeroderma Pigmentosum, Complementation Group C) A protein involved in the process of nucleotide excision repair of DNA. Mutations also cause xeroderma pigmentosis."

* #cancr0004.00207 "XRCC2 (X-Ray Repair Cross Complementing 2) Gomologik rekombinatsiya va DNKni tiklashda ishtirok etadigan oqsil. Mutatsiyalar turli xil saraton turlarini rivojlanish xavfi bilan bog'liq bo'lishi mumkin."
  * ^designation[0].language = #ru
  * ^designation[=].value = "XRCC2 (X-Ray Repair Cross Complementing 2)Белок, участвующий в гомологичной рекомбинации и репарации ДНК. Мутации могут быть связаны с повышенным риском различных видов рака."
  * ^designation[+].language = #en
  * ^designation[=].value = "XRCC2 (X-Ray Repair Cross Complementing 2) A protein involved in homologous recombination and DNA repair. Mutations may be associated with an increased risk of various cancers."

* #cancr0004.00208 "XRCC3 (X-Ray Repair Cross Complementing 3) Gomologik rekombinatsiya va DNKni tiklashda ishtirok etadigan oqsil. Mutatsiyalar, shuningdek, saratonning har xil turlarini rivojlanish xavfi bilan bog'liq bo'lishi mumkin."
  * ^designation[0].language = #ru
  * ^designation[=].value = "XRCC3 (X-Ray Repair Cross Complementing 3)Белок, участвующий в гомологичной рекомбинации и репарации ДНК. Мутации также могут быть связаны с повышенным риском различных видов рака."
  * ^designation[+].language = #en
  * ^designation[=].value = "XRCC3 (X-Ray Repair Cross Complementing 3) A protein involved in homologous recombination and DNA repair. Mutations may also be associated with an increased risk of various cancers."